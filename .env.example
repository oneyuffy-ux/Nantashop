# ─────────────────────────────────────────────
#  NantaShop — Environment Variables Example
#  คัดลอกไฟล์นี้เป็น .env แล้วแก้ไขค่าต่างๆ
# ─────────────────────────────────────────────

# PostgreSQL Connection String (จำเป็นต้องมี)
# รูปแบบ: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/nantashop

# Session Secret — ใส่ค่าสุ่มยาวๆ ห้ามใช้ค่านี้ใน production
SESSION_SECRET=change-this-to-a-long-random-secret-string

# Port ของ API Server (default: 5000)
PORT=5000

# Node environment
NODE_ENV=production

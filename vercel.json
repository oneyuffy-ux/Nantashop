{
  "version": 2,
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run build",
  "outputDirectory": "artifacts/game-shop/dist/public",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "artifacts/api-server/index.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}

{
  "version": 2,
  "buildCommand": "pnpm install && pnpm -r run build",
  "outputDirectory": "artifacts/game-shop/dist/public",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "artifacts/api-server/src/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
